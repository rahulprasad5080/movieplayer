<?xml version="1.0" encoding="utf-8"?>
<!--
    Custom player control layout for Media3 PlayerView.
    This replaces the default controller so we can match our design system.
    ExoPlayer will inflate this and bind the standard IDs automatically.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_player_controller_gradient">

    <!-- ── Center playback controls ─────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutCenterControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/layoutSeekBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Rewind 10s – Media3 auto-binds to @id/exo_rew -->
        <ImageButton
            android:id="@id/exo_rew"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_control_button"
            android:contentDescription="Rewind 10 seconds"
            android:padding="12dp"
            android:src="@drawable/ic_replay_10"
            android:tint="@color/white" />

        <!-- Play / Pause – Media3 auto-binds to @id/exo_play_pause -->
        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_play_pause_button"
            android:contentDescription="Play / Pause"
            android:padding="16dp"
            android:src="@drawable/ic_play"
            android:tint="@color/white" />

        <!-- Forward 10s – Media3 auto-binds to @id/exo_ffwd -->
        <ImageButton
            android:id="@id/exo_ffwd"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_control_button"
            android:contentDescription="Fast forward 10 seconds"
            android:padding="12dp"
            android:src="@drawable/ic_forward_10"
            android:tint="@color/white" />

    </LinearLayout>

    <!-- ── Bottom seek bar + time ────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutSeekBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="24dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Current position – Media3 binds @id/exo_position -->
            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit_regular"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Duration – Media3 binds @id/exo_duration -->
            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/outfit_regular"
                android:textColor="@color/white"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Seek bar – Media3 binds @id/exo_progress -->
        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:layout_marginTop="4dp"
            app:played_color="@color/accent_primary"
            app:buffered_color="#66FFFFFF"
            app:unplayed_color="#44FFFFFF"
            app:scrubber_color="@color/accent_primary"
            app:scrubber_enabled_size="14dp"
            app:scrubber_dragged_size="20dp"
            app:scrubber_disabled_size="10dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
