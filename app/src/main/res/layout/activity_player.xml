<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_player"
    tools:context=".ui.PlayerActivity">

    <!-- ── ExoPlayer PlayerView ─────────────────────────────────── -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:controller_layout_id="@layout/custom_player_control"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:resize_mode="fit"
        app:show_buffering="always"
        app:surface_type="surface_view"
        app:use_artwork="false" />

    <!-- ── Buffering Overlay ──────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBuffering"
        style="?android:attr/progressBarStyle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:indeterminateTint="@color/accent_primary"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <!-- ── Overlay Controls ───────────────────────────────────────── -->
    <!-- Back button (top-left) -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_control_button"
        android:contentDescription="Back"
        android:padding="10dp"
        android:src="@drawable/ic_arrow_back"
        android:tint="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- App title (top-center) -->
    <TextView
        android:id="@+id/tvPlayerTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/outfit_semibold"
        android:gravity="center"
        android:text="Now Playing"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/btnAudioTrack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Audio track selector (top-right) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/audioTrackContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnAudioTrack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_audio_button"
            android:contentDescription="Select Audio Track"
            android:padding="10dp"
            android:src="@drawable/ic_audio_tracks"
            android:tint="@color/white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge showing number of tracks -->
        <TextView
            android:id="@+id/tvTrackCount"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/bg_track_badge"
            android:fontFamily="@font/outfit_bold"
            android:gravity="center"
            android:text=""
            android:textColor="@color/white"
            android:textSize="10sp"
            app:layout_constraintEnd_toEndOf="@id/btnAudioTrack"
            app:layout_constraintTop_toTopOf="@id/btnAudioTrack" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
